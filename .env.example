# Hugging Face access token, required for the pyannote speaker-diarization
# model used by whisperx. Create a token at https://huggingface.co/settings/tokens
# and accept the model terms at https://huggingface.co/pyannote/speaker-diarization
HF_TOKEN=your_huggingface_token_here

# Whisper model size: tiny, base, small, medium, large, large-v2, large-v3
WHISPER_MODEL=large

# Device to run inference on: cuda or cpu (auto-detected if unset)
DEVICE=

# Flask server settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Maximum upload size in megabytes
MAX_UPLOAD_MB=200
